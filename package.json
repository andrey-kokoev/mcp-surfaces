{
  "name": "mcp-surfaces",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "description": "Standalone MCP surface packages shared by Narada sites and carriers.",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm -r test",
    "test:local-filesystem": "pnpm --filter @narada2/local-filesystem-mcp test",
    "test:mcp-transport": "pnpm --filter @narada2/mcp-transport test",
    "test:mcp-telemetry": "pnpm --filter @narada2/mcp-telemetry test",
    "test:mcp-runtime-proxy": "pnpm --filter @narada2/mcp-runtime-proxy test",
    "test:structured-command": "pnpm --filter @narada2/structured-command-mcp test",
    "test:git": "pnpm --filter @narada2/git-mcp test",
    "test:completion-audit": "pnpm --filter @narada2/completion-audit-mcp test",
    "test:delegated-task": "pnpm --filter @narada2/delegated-task-mcp test",
    "test:delegated-task:live": "pnpm --filter @narada2/delegated-task-mcp test:live",
    "test:worker-delegation": "pnpm --filter @narada2/worker-delegation-mcp test",
    "test:inbox": "pnpm --filter @narada2/site-inbox-mcp test",
    "test:mailbox": "pnpm --filter @narada2/mailbox-mcp test",
    "test:graph-mail": "pnpm --filter @narada2/graph-mail-mcp test",
    "test:calendar": "pnpm --filter @narada2/calendar-mcp test",
    "test:task-lifecycle": "pnpm --filter @narada2/task-lifecycle-mcp test",
    "test:site-loop": "pnpm --filter @narada2/site-loop-mcp test",
    "test:agent-context": "pnpm --filter @narada2/agent-context-mcp test",
    "test:sop": "pnpm --filter @narada2/sop-mcp test",
    "test:scheduler": "pnpm --filter @narada2/scheduler-mcp test",
    "test:registrar": "pnpm --filter @narada2/mcp-registrar test",
    "test:site-lifecycle": "pnpm --filter @narada2/site-lifecycle-mcp test",
    "test:surface-feedback": "pnpm --filter @narada2/surface-feedback-mcp test",
    "test:launcher": "pnpm --filter @narada2/launcher-mcp test",
    "test:runtime-introspection": "pnpm --filter @narada2/runtime-introspection-mcp test",
    "test:speech": "pnpm --filter @narada2/speech-mcp test",
    "test:cloudflare-carrier": "pnpm --filter @narada2/cloudflare-carrier-mcp test",
    "test:site-coherence": "pnpm --filter @narada2/site-coherence-mcp test",
    "test:artifacts": "pnpm --filter @narada2/artifacts-mcp test"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.9.0"
}
