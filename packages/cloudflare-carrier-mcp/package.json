{
  "name": "@narada2/cloudflare-carrier-mcp",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "description": "Cloudflare-carrier live operations MCP surface wrapping product-read, session capture, and continuity sync.",
  "bin": {
    "cloudflare-carrier-mcp": "./dist/src/main.js"
  },
  "types": "./dist/src/main.d.ts",
  "exports": {
    "./surface-definition": {
      "types": "./dist/src/surface-definition.d.ts",
      "default": "./dist/src/surface-definition.js"
    },
    ".": {
      "types": "./dist/src/main.d.ts",
      "default": "./dist/src/main.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm --filter @narada2/mcp-e2e-harness build && pnpm build && node dist/test/protocol-smoke.test.js && node dist/test/cloudflare-carrier-mcp.test.js && node dist/test/site-fabric-cloudflare-e2e.test.js",
    "test:e2e:site-fabric": "pnpm --filter @narada2/mcp-e2e-harness build && pnpm build && node dist/test/site-fabric-cloudflare-e2e.test.js",
    "test:e2e:cloudflare-live": "pnpm --filter @narada2/mcp-e2e-harness build && pnpm build && node dist/test/cloudflare-carrier-live-e2e.test.js"
  },
  "dependencies": {
    "@narada2/mcp-fabric-contracts": "workspace:*",
    "@narada2/mcp-e2e-harness": "workspace:*"
  },
  "files": [
    "dist/"
  ]
}
