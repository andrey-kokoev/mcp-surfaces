{
  "name": "@narada2/delegated-task-mcp",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "description": "Delegated task orchestration MCP surface.",
  "bin": {
    "delegated-task-mcp": "./dist/src/main.js"
  },
  "types": "./dist/src/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/main.d.ts",
      "default": "./dist/src/main.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm build && node dist/test/run-tests.js",
    "test:coverage": "pnpm build && c8 --all --src=dist/src --include=dist/src/**/*.js --temp-directory=.tmp/c8 --reporter=text --check-coverage --statements=90 --lines=90 --branches=74 --functions=95 node dist/test/run-tests.js",
    "test:live": "pnpm build && node dist/test/live-worker-integration.test.js",
    "test:live:provider": "pnpm build && node dist/test/live-worker-integration.test.js --provider"
  },
  "dependencies": {
    "@narada2/worker-delegation-mcp": "workspace:*"
  },
  "files": [
    "dist/",
    "README.md",
    "target.md",
    "task-graph.md"
  ],
  "devDependencies": {
    "c8": "^11.0.0"
  }
}
