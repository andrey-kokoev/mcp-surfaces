{
  "name": "@narada2/git-mcp",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "description": "Structured, policy-gated Git management MCP surface.",
  "bin": {
    "git-mcp": "./dist/src/main.js"
  },
  "types": "./dist/src/main.d.ts",
  "exports": {
    "./surface-definition": {
      "types": "./dist/src/surface-definition.d.ts",
      "default": "./dist/src/surface-definition.js"
    },
    ".": {
      "types": "./dist/src/main.d.ts",
      "default": "./dist/src/main.js"
    },
    "./policy": {
      "types": "./dist/src/policy.d.ts",
      "default": "./dist/src/policy.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm build && node dist/test/git-mcp.test.js && node dist/test/protocol-smoke.test.js && node dist/test/site-fabric-git-e2e.test.js"
  },
  "dependencies": {
    "@narada2/mcp-fabric-contracts": "workspace:*",
    "@narada2/mcp-transport": "workspace:*"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "devDependencies": {
    "@narada2/mcp-e2e-harness": "workspace:*"
  }
}
