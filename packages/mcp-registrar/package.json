{
  "name": "@narada2/mcp-registrar",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "description": "MCP surface registrar for binding/unbinding surfaces across Narada sites and carriers (opencode, Kimi, Codex).",
  "bin": {
    "mcp-registrar": "./dist/src/main.js"
  },
  "types": "./dist/src/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/main.d.ts",
      "default": "./dist/src/main.js"
    },
    "./surface-definition": {
      "types": "./dist/src/surface-definition.d.ts",
      "default": "./dist/src/surface-definition.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm -w build && pnpm run test:kimi-contract:run && node dist/test/mcp-fabric-v2-native.test.js && node dist/test/mcp-registrar.test.js && node dist/test/protocol-smoke.test.js && node dist/test/site-fabric-loader-e2e.test.js && node dist/test/site-fabric-catalog-e2e.test.js",
    "test:kimi-contract:run": "node dist/test/moonshot-schema.test.js && node dist/test/kimi-carrier-contract.test.js",
    "test:kimi-contract": "pnpm -w build && pnpm run test:kimi-contract:run",
    "test:kimi-live": "pnpm -w build && node dist/test/kimi-carrier-live-e2e.test.js"
  },
  "dependencies": {
    "@narada2/local-filesystem-mcp": "workspace:*",
    "@narada2/structured-command-mcp": "workspace:*",
    "@narada2/git-mcp": "workspace:*",
    "@narada2/site-inbox-mcp": "workspace:*",
    "@narada2/mailbox-mcp": "workspace:*",
    "@narada2/graph-mail-mcp": "workspace:*",
    "@narada2/calendar-mcp": "workspace:*",
    "@narada2/task-lifecycle-mcp": "workspace:*",
    "@narada2/site-loop-mcp": "workspace:*",
    "@narada2/site-lifecycle-mcp": "workspace:*",
    "@narada2/site-registry-mcp": "workspace:*",
    "@narada2/agent-context-mcp": "workspace:*",
    "@narada2/worker-delegation-mcp": "workspace:*",
    "@narada2/delegated-task-mcp": "workspace:*",
    "@narada2/sop-mcp": "workspace:*",
    "@narada2/scheduler-mcp": "workspace:*",
    "@narada2/mcp-loader-mcp": "workspace:*",
    "@narada2/surface-feedback-mcp": "workspace:*",
    "@narada2/launcher-mcp": "workspace:*",
    "@narada2/speech-mcp": "workspace:*",
    "@narada2/operator-routing-mcp": "workspace:*",
    "@narada2/artifacts-mcp": "workspace:*",
    "@narada2/nars-session-mcp": "workspace:*",
    "@narada2/cloudflare-carrier-mcp": "workspace:*",
    "@narada2/site-coherence-mcp": "workspace:*",
    "@narada2/mcp-fabric-compiler": "workspace:*",
    "@narada2/mcp-fabric-contracts": "workspace:*",
    "@narada2/mcp-transport": "workspace:*",
    "@narada2/mcp-runtime-proxy": "workspace:*"
  },
  "files": [
    "dist/",
    "sops/"
  ],
  "devDependencies": {
    "@narada2/mcp-e2e-harness": "workspace:*"
  }
}
