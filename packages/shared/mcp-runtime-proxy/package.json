{
  "name": "@narada2/mcp-runtime-proxy",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm --filter @narada2/mcp-e2e-harness build && pnpm build && node dist/test/mcp-runtime-proxy.test.js && node dist/test/generation-manager.test.js && node --test dist/test/runtime-observation.test.js"
  },
  "types": "./dist/src/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/main.d.ts",
      "default": "./dist/src/main.js"
    },
    "./generation-manager": {
      "types": "./dist/src/generation-manager.d.ts",
      "default": "./dist/src/generation-manager.js"
    },
    "./runtime-observation": {
      "types": "./dist/src/runtime-observation.d.ts",
      "default": "./dist/src/runtime-observation.js"
    }
  },
  "dependencies": {
    "@narada2/mcp-fabric-contracts": "workspace:*"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "devDependencies": {
    "@narada2/mcp-e2e-harness": "workspace:*"
  }
}
