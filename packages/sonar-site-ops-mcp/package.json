{
  "name": "@narada2/sonar-site-ops-mcp",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "description": "Sonar site-ops MCP runtime and site loop tools.",
  "bin": {
    "sonar-site-ops-mcp": "./dist/src/site-ops-mcp-server.js"
  },
  "exports": {
    ".": { "default": "./dist/src/site-ops-mcp-server.js" },
    "./site-ops-mcp-server": { "default": "./dist/src/site-ops-mcp-server.js" },
    "./site-loop/sonar-email-resident-loop": { "default": "./dist/src/site-loop/sonar-email-resident-loop.js" },
    "./site-operating-loop/site-loop-store": { "default": "./dist/src/site-operating-loop/site-loop-store.js" },
    "./site-operating-loop/policy": { "default": "./dist/src/site-operating-loop/policy.js" }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm build && node dist/test/syntax-check-all.js && node dist/test/protocol-smoke.test.js"
  },
  "dependencies": {
    "@narada2/mcp-transport": "workspace:*",
    "@narada2/task-governance-core": "workspace:*",
    "@narada2/task-lifecycle-mcp": "workspace:*"
  },
  "files": ["dist/"]
}
