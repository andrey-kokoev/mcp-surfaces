{
  "name": "@narada2/task-lifecycle-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "Task lifecycle MCP stdio runtime and tool dispatch surface.",
  "bin": {
    "task-lifecycle-mcp": "./dist/src/task-lifecycle/task-mcp-server.js"
  },
  "exports": {
    ".": {
      "default": "./dist/src/task-lifecycle/task-mcp-server.js"
    },
    "./task-lifecycle-mcp-server": {
      "default": "./dist/src/task-lifecycle/task-mcp-server.js"
    },
    "./task-lifecycle-runtime/agent-role-resolution": { "default": "./dist/src/task-lifecycle/agent-role-resolution.js" },
    "./task-lifecycle-runtime/closure-authority": { "default": "./dist/src/task-lifecycle/closure-authority.js" },
    "./task-lifecycle-runtime/emit-checkpoint": { "default": "./dist/src/task-lifecycle/emit-checkpoint.js" },
    "./task-lifecycle-runtime/follow-up-ledger-validation": { "default": "./dist/src/task-lifecycle/follow-up-ledger-validation.js" },
    "./task-lifecycle-runtime/follow-up-policy-service": { "default": "./dist/src/task-lifecycle/follow-up-policy-service.js" },
    "./task-lifecycle-runtime/inbox-bridge": { "default": "./dist/src/task-lifecycle/inbox-bridge.js" },
    "./task-lifecycle-runtime/inbox-workboard": { "default": "./dist/src/task-lifecycle/inbox-workboard.js" },
    "./task-lifecycle-runtime/operator-identity": { "default": "./dist/src/task-lifecycle/operator-identity.js" },
    "./task-lifecycle-runtime/recovery-truthfulness-guard": { "default": "./dist/src/task-lifecycle/recovery-truthfulness-guard.js" },
    "./task-lifecycle-runtime/self-certification-guard": { "default": "./dist/src/task-lifecycle/self-certification-guard.js" },
    "./task-lifecycle-runtime/task-lifecycle-mutation-services": { "default": "./dist/src/task-lifecycle/task-lifecycle-mutation-services.js" },
    "./task-lifecycle-runtime/task-relatedness": { "default": "./dist/src/task-lifecycle/task-relatedness.js" },
    "./task-lifecycle-runtime/unified-workboard": { "default": "./dist/src/task-lifecycle/unified-workboard.js" },
    "./task-lifecycle-runtime/workboard": { "default": "./dist/src/task-lifecycle/workboard.js" }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm build && node --disable-warning=ExperimentalWarning dist/test/syntax-check-all.js && node --disable-warning=ExperimentalWarning dist/test/import-boundary.test.js && node --disable-warning=ExperimentalWarning dist/test/handler-coverage.test.js && node --disable-warning=ExperimentalWarning dist/test/stdio-smoke.test.js && node --disable-warning=ExperimentalWarning dist/test/protocol-smoke.test.js"
  },
  "dependencies": {
    "@narada2/mcp-transport": "workspace:*",
    "@narada2/task-governance-core": "workspace:*"
  },
  "files": ["dist/"]
}
