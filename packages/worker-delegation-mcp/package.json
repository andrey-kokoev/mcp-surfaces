{
  "name": "@narada2/worker-delegation-mcp",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "description": "Policy-gated worker delegation MCP surface.",
  "bin": {
    "worker-delegation-mcp": "./dist/src/main.js"
  },
  "types": "./dist/src/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/main.d.ts",
      "default": "./dist/src/main.js"
    }
  },
  "scripts": {
    "build": "tsc -b && pnpm run build:postcompile",
    "build:postcompile": "node ./dist/src/implementation-identity-manifest.js",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm build && node dist/test/run-tests.js",
    "test:e2e:edit": "pnpm --filter @narada2/local-filesystem-mcp build && pnpm build && node dist/test/live-edit-e2e.test.js",
    "test:e2e:site-fabric": "pnpm --filter @narada2/local-filesystem-mcp build && pnpm --filter @narada2/mcp-loader-mcp build && pnpm build && node dist/test/site-fabric-provider-e2e.test.js",
    "test:e2e:carrier": "pnpm build && node dist/test/real-carrier-e2e.test.js",
    "test:coverage": "pnpm build && c8 --all --src=dist/src --include=dist/src/**/*.js --temp-directory=.tmp/c8 --reporter=text --check-coverage --statements=88 --lines=88 --branches=76 --functions=93 node dist/test/run-tests.js",
    "test:coverage:cognition": "pnpm build && c8 --all --src=dist/src --include=dist/src/cognition-defaults.js --temp-directory=.tmp/c8-cognition --reporter=text --check-coverage --statements=96 --lines=96 --branches=77 --functions=100 node dist/test/cognition-defaults.test.js"
  },
  "dependencies": {
    "@narada2/mcp-affordances": "workspace:*",
    "@narada2/mcp-transport": "workspace:*",
    "zod": "^4.4.3"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "devDependencies": {
    "@narada2/mcp-runtime-proxy": "workspace:*",
    "c8": "^11.0.0"
  }
}
